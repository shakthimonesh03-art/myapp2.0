function generateSeats(prefix: string, total: number): { id: string; label: string; status: 'AVAILABLE' | 'BOOKED' | 'BLOCKED' }[] {
  return Array.from({ length: total }).map((_, i) => ({
    id: `${prefix}${i + 1}`,
    label: `${prefix}${i + 1}`,
    status: i % 13 === 0 ? 'BOOKED' : 'AVAILABLE'
  }));
}


