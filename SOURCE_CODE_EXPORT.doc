:root {
  color-scheme: dark;
  --bg: #0a0722;
  --panel: rgba(18, 17, 45, 0.92);
  --line: rgba(255, 255, 255, 0.16);
  --text: #ffffff;
  --muted: #d0d7ff;
  --accent1: #6a5cff;
  --accent2: #28d4ff;
  --fs-h1: clamp(1.8rem, 2.8vw, 2.6rem);
  --fs-h2: clamp(1.35rem, 2vw, 1.95rem);
  --fs-body: clamp(0.92rem, 1.1vw, 1rem);
}


* { box-sizing: border-box; }
body {
  margin: 0;
  font-family: 'Inter', 'Poppins', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
  color: var(--text);
  background:
    radial-gradient(circle at 20% 10%, rgba(106, 92, 255, .35), transparent 30%),
    radial-gradient(circle at 80% 20%, rgba(40, 212, 255, .2), transparent 25%),
    var(--bg);
}
a { color: inherit; text-decoration: none; }
.container { width: min(1180px, 92vw); margin: 0 auto; }
.page-wrap { padding: 1rem 0 2.6rem; }

.topbar {
  position: sticky;
  top: 0;
  z-index: 100;
  border-bottom: 1px solid var(--line);
  background: rgba(8, 8, 22, .72);
  backdrop-filter: blur(12px);
}
.nav-shell { display: flex; justify-content: space-between; align-items: center; gap: 1rem; padding: .85rem 0; flex-wrap: wrap; }
.brand { display: grid; font-weight: 800; letter-spacing: .2px; }
.brand span { font-size: .75rem; color: var(--muted); font-weight: 500; }
.navlinks { display: flex; gap: .9rem; flex-wrap: wrap; }
.navlinks a { padding: .4rem .65rem; border-radius: 999px; border: 1px solid transparent; }
.navlinks a:hover { border-color: var(--line); background: rgba(255,255,255,.06); }

.stack-xl { display: grid; gap: 1.2rem; }
.stack { display: grid; gap: 1rem; }
.card { background: var(--panel); border: 1px solid var(--line); border-radius: 24px; padding: 1rem; }
.auth-card { max-width: 520px; margin: 0 auto; }
.warning { color: var(--muted); }
.panel {
  background: linear-gradient(170deg, rgba(31, 30, 73, .72), var(--panel));
  border: 1px solid var(--line);
  border-radius: 26px;
  padding: 1rem;
  box-shadow: 0 18px 40px rgba(0, 0, 0, .2);
}

.hero-shell {
  display: grid;
  grid-template-columns: 2fr 1fr;
  gap: 1rem;
  align-items: stretch;
  padding: 1.2rem;
  border: 1px solid var(--line);
  border-radius: 20px;
  background: linear-gradient(130deg, rgba(106, 92, 255, .28), rgba(40, 212, 255, .08));
}
.hero-content h1 { margin: 0; font-size: clamp(1.5rem, 3vw, 2.4rem); line-height: 1.2; }
.eyebrow { text-transform: uppercase; letter-spacing: .12em; font-size: .75rem; color: var(--muted); }
.subtitle { color: var(--muted); max-width: 58ch; }
.hero-cta { display: flex; gap: .7rem; flex-wrap: wrap; }
.hero-stats { display: grid; gap: .6rem; }
.hero-stats article { border: 1px solid var(--line); background: rgba(255,255,255,.04); border-radius: 22px; padding: .8rem; display: grid; }
.hero-stats strong { font-size: 1.2rem; }
.hero-stats span { color: var(--muted); font-size: .88rem; }

.filters { display: grid; grid-template-columns: repeat(3, minmax(160px, 1fr)); gap: .8rem; }
.input, select {
  min-height: 42px;
  border: 1px solid var(--line);
  background: rgba(255, 255, 255, .03);
  color: #fff;
  border-radius: 18px;
  padding: 0 .75rem;
}

.event-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 1rem; }
.event-card { background: var(--panel); border: 1px solid var(--line); border-radius: 24px; padding: 1rem; display: grid; gap: .55rem; }
.card-foot { display: flex; justify-content: space-between; align-items: center; gap: .8rem; }
.pill { width: max-content; padding: .2rem .5rem; border-radius: 999px; background: rgba(106, 92, 255, .25); font-size: .75rem; }

.btn {
  border: 0;
  color: #fff;
  border-radius: 18px;
  cursor: pointer;
  font-weight: 700;
  display: inline-flex;
  justify-content: center;
  align-items: center;
  padding: .65rem 1rem;
  background: linear-gradient(120deg, var(--accent1), var(--accent2));
}
.btn.ghost { background: transparent; border: 1px solid var(--line); }

.row { display: flex; }
.between { justify-content: space-between; }
.center { align-items: center; }
.wrap { flex-wrap: wrap; }
.gap-sm { gap: .75rem; }

.hero-mini h1 { margin-top: 0; }
.seats { display: grid; gap: .5rem; grid-template-columns: repeat(8, minmax(40px,1fr)); margin-top: .8rem; }
.seat { padding: .45rem; border-radius: 8px; border: 1px solid var(--line); background:#171b31; color:#d7defc; }
.seat.active { background: #4051ff; color: #fff; }
.seat:disabled { opacity:.45; cursor:not-allowed; }
.muted { color: var(--muted); }

.qr { width: 240px; max-width: 100%; background: #fff; padding: .5rem; border-radius: 8px; }
.razorpay-box { margin-top: .9rem; padding: .9rem; border-radius: 22px; border: 1px dashed rgba(40, 212, 255, .55); background: rgba(40, 212, 255, .08); }

@media (max-width: 920px) {
  .hero-shell { grid-template-columns: 1fr; }
  .filters { grid-template-columns: 1fr; }
}

.modern-page {
  min-height: calc(100vh - 90px);
  background: radial-gradient(circle at top left, rgba(51, 88, 255, 0.22), transparent 32%), linear-gradient(180deg, #060817, #040414);
  color: #f8fbff;
  border-radius: 26px;
  padding: 1rem;
}
.modern-page * { color: inherit; }
.modern-nav {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 1rem;
  padding: .7rem 1rem;
  border-radius: 22px;
  background: rgba(13, 24, 62, .9);
  border: 1px solid rgba(148, 163, 255, .35);
  box-shadow: 0 6px 20px rgba(0, 0, 0, .25);
}
.logo { font-weight: 800; color: #c7d4ff; font-size: 1.25rem; }
.modern-actions { display: flex; align-items: center; gap: .8rem; }
.top-link { color: #d6e1ff; }
.location-btn {
  border: 1px solid rgba(148, 163, 255, .35);
  background: rgba(75, 109, 255, 0.28);
  color: #ffffff;
  padding: .55rem .9rem;
  border-radius: 999px;
  cursor: pointer;
}
.modern-main { max-width: 1120px; margin: 0 auto; padding: 1.6rem .3rem; }
.modern-header h1 { margin: 0 0 .3rem; font-size: var(--fs-h1); line-height: 1.18; letter-spacing: -.015em; }
.modern-header p { margin: 0 0 1.1rem; color: #c7d4ff; font-size: var(--fs-body); line-height: 1.6; }
.modern-header span { color: #7fb0ff; font-weight: 600; }
.modern-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 1rem; }
.modern-card {
  background: rgba(13, 24, 62, .9);
  border: 1px solid rgba(148, 163, 255, .25);
  border-radius: 26px;
  padding: 1rem;
  box-shadow: 0 14px 30px rgba(0, 0, 0, .25);
  transition: transform .2s ease;
  animation: fadeUp .4s ease both;
}
.modern-card:hover { transform: translateY(-4px); }
.icon-chip {
  width: 44px;
  height: 44px;
  display: grid;
  place-items: center;
  border-radius: 20px;
  background: #3b82f6;
  color: #fff;
  font-weight: 700;
}
.modal-root {
  position: fixed;
  inset: 0;
  z-index: 200;
  display: grid;
  place-items: center;
  padding: 1rem;
}
.modal-backdrop {
  position: absolute;
  inset: 0;
  background: rgba(15, 23, 42, .45);
  backdrop-filter: blur(4px);
}
.modal-card {
  position: relative;
  max-width: 840px;
  width: 100%;
  background: #0b1232;
  color: #fff;
  border-radius: 28px;
  padding: 1.4rem;
  box-shadow: 0 24px 60px rgba(15, 23, 42, .35);
}
.location-search { margin: .8rem 0; background: rgba(6, 10, 28, .88) !important; color: #fff !important; }
.location-current-btn {
  border: 0;
  background: transparent;
  color: #4f46e5;
  font-weight: 700;
  cursor: pointer;
  margin-bottom: .9rem;
}
.location-popular-grid {
  display: grid;
  grid-template-columns: repeat(5, minmax(0, 1fr));
  gap: .7rem;
}
.location-popular-item {
  border: 1px solid rgba(148, 163, 255, .35);
  border-radius: 16px;
  padding: .65rem;
  background: rgba(75, 109, 255, 0.28);
  display: grid;
  gap: .25rem;
  justify-items: center;
  cursor: pointer;
}
.location-icon { font-size: 1.2rem; }
.location-all-title { margin: 1rem 0 .5rem; }
.location-alpha { color: #a8bcff; letter-spacing: .22em; margin-bottom: .5rem; font-size: .85rem; }
.location-list-columns {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: .45rem .9rem;
  max-height: 220px;
  overflow: auto;
}
.location-list-city {
  border: 0;
  text-align: left;
  background: transparent;
  cursor: pointer;
  color: #fff;
  padding: .2rem 0;
}
.location-list { display: grid; gap: .6rem; margin-top: .8rem; }
.location-item {
  width: 100%;
  display: flex;
  justify-content: space-between;
  border: 1px solid #e2e8f0;
  border-radius: 20px;
  background: #fff;
  padding: .85rem 1rem;
  cursor: pointer;
}
.location-item:hover { border-color: #3b82f6; background: #eff6ff; color: #1d4ed8; }
.pop-in { animation: pop .24s ease both; }
@keyframes pop { from { opacity: 0; transform: translateY(10px) scale(.98);} to {opacity:1; transform: none;} }
@keyframes fadeUp { from {opacity:0; transform: translateY(10px);} to {opacity:1; transform:none;} }

.modern-page .input, .modern-page select {
  background: rgba(6, 10, 28, .88);
  color: #fff;
  border-color: rgba(148, 163, 255, .35);
}

.bookings-dashboard {
  min-height: calc(100vh - 100px);
  background: radial-gradient(circle at top left, rgba(51, 88, 255, 0.22), transparent 32%), linear-gradient(180deg, #060817, #040414);
  border-radius: 28px;
  padding: 1.4rem;
}
.bookings-header h1 {
  margin: .3rem 0 1rem;
  font-size: clamp(1.8rem, 3vw, 2.4rem);
  font-weight: 800;
  color: #f8fbff;
}
.bookings-list { display: grid; gap: 1rem; }
.bookings-grid-3 {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 1rem;
}
.bookings-subtitle {
  margin: .4rem 0 .8rem;
  color: #dce7ff;
  font-size: 1.2rem;
}
.booking-card {
  background: rgba(14, 19, 43, 0.9);
  border: 1px solid rgba(123, 141, 255, 0.35);
  border-radius: 26px;
  padding: 1.05rem;
  box-shadow: 0 14px 30px rgba(0, 0, 0, .25);
  color: #eaf1ff;
  display: grid;
  gap: .55rem;
}
.booking-card h3 { margin-top: 0; margin-bottom: .8rem; font-size: var(--fs-h2); line-height: 1.25; letter-spacing: -.01em; }
.status-confirmed { color: #2ddc84; font-weight: 700; }
.status-cancelled { color: #ff6f6f; font-weight: 700; }
.booking-cta {
  width: 100%;
  margin-top: .5rem;
  margin-bottom: .6rem;
  background: linear-gradient(120deg, #3a5eff, #24d7ff);
  box-shadow: 0 0 0 rgba(36, 215, 255, 0);
  transition: box-shadow .2s ease;
}
.booking-cta:hover { box-shadow: 0 0 20px rgba(36, 215, 255, .35); }
.asset-links {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
  gap: .45rem;
  margin: .2rem 0 .7rem;
}
.asset-links a {
  font-size: .85rem;
  color: #a7d4ff;
  text-decoration: underline;
  text-underline-offset: 2px;
}
.cancel-link {
  width: 100%;
  border-radius: 16px;
  border: 1px solid rgba(255,255,255,.24);
  background: transparent;
  color: #d6defe;
  padding: .45rem .8rem;
  cursor: pointer;
}
.notification-empty-note {
  margin: .25rem .2rem 0;
  color: #b8c9ff;
  font-size: 1rem;
}


/* Large screens: give cards more breathing room */
@media (min-width: 1200px) {
  .bookings-dashboard { padding: 2rem; }
  .bookings-list { gap: 1.4rem; }
  .bookings-grid-3 { gap: 1.2rem; }
  .booking-card { padding: 1.35rem; }
  .asset-links { grid-template-columns: repeat(4, minmax(140px, 1fr)); }
  .modern-main { max-width: 1180px; }
}

/* Mobile-first tuning for 360px devices */
@media (max-width: 420px) {
  .container { width: min(96vw, 420px); }
  .page-wrap { padding-top: .6rem; }
  .nav-shell { padding: .55rem 0; }
  .navlinks { gap: .4rem; }
  .navlinks a { padding: .32rem .5rem; font-size: .74rem; }
  .modern-page { padding: .75rem; border-radius: 18px; }
  .modern-nav { padding: .55rem .7rem; }
  .modern-main { padding: 1rem .1rem; }
  .modern-grid { grid-template-columns: 1fr; }
  .location-popular-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  .location-list-columns { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  .bookings-dashboard { padding: .85rem; border-radius: 20px; }
  .bookings-header h1 { margin-bottom: .7rem; }
  .bookings-grid-3 { grid-template-columns: 1fr; }
  .booking-card { padding: .85rem; border-radius: 20px; }
  .booking-cta { margin-top: .35rem; }
  .asset-links { grid-template-columns: 1fr 1fr; }
  .cancel-link { border-radius: 12px; }
}

/* Admin Console */
.admin-shell {
  display: grid;
  grid-template-columns: 280px 1fr;
  min-height: calc(100vh - 64px);
  gap: 0;
  background: radial-gradient(circle at top left, rgba(51, 88, 255, 0.22), transparent 32%), linear-gradient(180deg, #060817, #040414);
  color: #fff;
}

.admin-shell * { color: #fff; }

.admin-sidebar {
  background: rgba(10, 17, 44, 0.95);
  border-right: 1px solid rgba(148, 163, 255, .25);
  padding: 24px 16px;
  position: sticky;
  top: 64px;
  height: calc(100vh - 64px);
}

.admin-sidebar h2 { margin: 0 0 16px; font-size: 1.05rem; }

.admin-nav-item {
  display: block;
  padding: 10px 12px;
  border-radius: 10px;
  color: #fff;
  text-decoration: none;
  margin-bottom: 8px;
}

.admin-nav-item.active,
.admin-nav-item:hover { background: rgba(75, 109, 255, 0.32); color: #fff; }

.admin-main { padding: 24px; }

.admin-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: rgba(13, 24, 62, .9);
  border: 1px solid rgba(148, 163, 255, .35);
  border-radius: 14px;
  padding: 16px 20px;
  margin-bottom: 20px;
}

.admin-header h1 { margin: 0 0 4px; font-size: 1.2rem; }
.admin-header p { margin: 0; color: #e5ecff; }
.admin-user-pill { background: rgba(75, 109, 255, 0.32); color: #fff; padding: 8px 12px; border-radius: 999px; font-size: 0.85rem; }

.admin-section { display: flex; flex-direction: column; gap: 16px; }
.admin-section h2 { margin: 0; font-size: 1.15rem; }

.admin-card-grid { display: grid; gap: 16px; }
.admin-card-grid.four { grid-template-columns: repeat(4, minmax(0, 1fr)); }
.admin-card-grid.three { grid-template-columns: repeat(3, minmax(0, 1fr)); }
.admin-card-grid.two { grid-template-columns: repeat(2, minmax(0, 1fr)); }

.admin-card {
  background: rgba(13, 24, 62, .9);
  border: 1px solid rgba(148, 163, 255, .25);
  border-radius: 14px;
  padding: 16px;
}

.admin-card h3 { margin-top: 0; }
.admin-link-card { text-decoration: none; color: #e5ecff; font-weight: 600; }

.admin-form {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 10px;
  background: rgba(13, 24, 62, .9);
  border: 1px solid rgba(148, 163, 255, .25);
  border-radius: 14px;
  padding: 14px;
}

.admin-form .input,
.admin-form select {
  background: rgba(6, 10, 28, .88);
  border-color: rgba(148, 163, 255, .35);
  color: #fff;
}

.event-form,
.seat-layout-form {
  grid-template-columns: repeat(3, minmax(0, 1fr));
}

.event-form .btn,
.seat-layout-form .btn {
  align-self: end;
}

.admin-table {
  width: 100%;
  border-collapse: collapse;
  background: rgba(13, 24, 62, .9);
  border: 1px solid rgba(148, 163, 255, .25);
  border-radius: 14px;
  overflow: hidden;
}

.admin-table th,
.admin-table td {
  text-align: left;
  padding: 10px 12px;
  border-bottom: 1px solid rgba(148, 163, 255, .16);
  vertical-align: middle;
}

.admin-table th { background: rgba(75, 109, 255, 0.24); font-weight: 600; }

.status-badge {
  border-radius: 999px;
  padding: 4px 10px;
  background: #f3f4f6;
  font-size: 0.8rem;
}
.status-badge.ok { background: #dcfce7; color: #000; }
.status-badge.warn { background: #fee2e2; color: #000; }

.admin-chart {
  display: flex;
  align-items: flex-end;
  gap: 14px;
  min-height: 140px;
  border: 1px dashed #d1d5db;
  border-radius: 10px;
  padding: 12px;
}

.admin-bar-wrap { display: flex; flex-direction: column; align-items: center; gap: 8px; }
.admin-bar { width: 28px; background: linear-gradient(180deg, #3b82f6 0%, #1d4ed8 100%); border-radius: 8px; }

.seat-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(78px, 1fr));
  gap: 8px;
}

.seat-cell {
  border: 1px solid #d1d5db;
  border-radius: 8px;
  padding: 8px;
  text-align: center;
  background: #f8fafc;
}

.seat-cell.vip { background: #fef3c7; }

.booking-box-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16px;
  background-color: #2a2a2a;
  background-image:
    linear-gradient(rgba(255, 255, 255, 0.08) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255, 255, 255, 0.08) 1px, transparent 1px);
  background-size: 34px 34px;
  border-radius: 16px;
  padding: 16px;
}

.booking-box-card {
  background: #24df00;
  border: 4px solid #ffffff;
  border-radius: 18px;
  padding: 14px;
  box-shadow: 0 8px 20px rgba(0, 0, 0, 0.18);
}

.booking-box-card p {
  margin: 0 0 8px;
  color: #052900 !important;
}

.booking-box-card p:last-child { margin-bottom: 0; }

.notification-box-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16px;
  background-color: #2a2a2a;
  background-image:
    linear-gradient(rgba(255, 255, 255, 0.08) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255, 255, 255, 0.08) 1px, transparent 1px);
  background-size: 34px 34px;
  border-radius: 16px;
  padding: 16px;
}

.notification-box-card {
  background: #24df00;
  border: 4px solid #ffffff;
  border-radius: 18px;
  padding: 14px;
  box-shadow: 0 8px 20px rgba(0, 0, 0, 0.18);
  color: #052900 !important;
}

.notification-box-card p,
.notification-box-card small { color: #052900 !important; }

@media (max-width: 1100px) {
  .admin-shell { grid-template-columns: 1fr; }
  .admin-sidebar { position: static; height: auto; border-right: none; border-bottom: 1px solid #e5e7eb; }
  .admin-card-grid.four,
  .admin-card-grid.three,
  .admin-card-grid.two,
  .admin-form,
  .booking-box-grid,
  .notification-box-grid,
  .bookings-grid-3 { grid-template-columns: 1fr; }
}


