services:
  zookeeper:
    image: confluentinc/cp-zookeeper:7.4.4
    container_name: ticketpulse-zookeeper
    environment:
      ZOOKEEPER_CLIENT_PORT: 2181
      ZOOKEEPER_TICK_TIME: 2000
    ports:
      - "2181:2181"

  kafka:
    image: confluentinc/cp-kafka:7.4.4
    container_name: ticketpulse-kafka
    depends_on:
      - zookeeper
    ports:
      - "9092:9092"
    environment:
      KAFKA_BROKER_ID: 1
      KAFKA_ZOOKEEPER_CONNECT: zookeeper:2181
      KAFKA_LISTENERS: PLAINTEXT://0.0.0.0:9092
      KAFKA_ADVERTISED_LISTENERS: PLAINTEXT://kafka:9092
      KAFKA_OFFSETS_TOPIC_REPLICATION_FACTOR: 1

  ticketpulse-web:
    build:
      context: .
      target: dev
    container_name: ticketpulse-web
    ports:
      - "3000:3000"
    volumes:
      - .:/app
      - /app/node_modules
      - /app/.next
    environment:
      NODE_ENV: development
      CHOKIDAR_USEPOLLING: "true"
      KAFKA_BROKERS: kafka:9092
      AWS_ACCESS_KEY_ID: ${AWS_ACCESS_KEY_ID:-}
      AWS_SECRET_ACCESS_KEY: ${AWS_SECRET_ACCESS_KEY:-}
      AWS_REGION: ${AWS_REGION:-ap-south-1}
      SNS_TOPIC_ARN: ${SNS_TOPIC_ARN:-arn:aws:sns:ap-south-1:478122456633:Ticketpulse}
      SQS_QUEUE_URL: ${SQS_QUEUE_URL:-https://sqs.ap-south-1.amazonaws.com/478122456633/myqueus}
      AUTH_SERVICE_URL: http://ticketpulse-auth:3101
      USER_SERVICE_URL: http://ticketpulse-user:3102
      EVENTS_SERVICE_URL: http://ticketpulse-events:3103
      VENUES_SERVICE_URL: http://ticketpulse-venues:3104
      INVENTORY_SERVICE_URL: http://ticketpulse-inventory:3105
      BOOKINGS_SERVICE_URL: http://ticketpulse-bookings:3106
      PAYMENTS_SERVICE_URL: http://ticketpulse-payments:3107
      NOTIFICATIONS_SERVICE_URL: http://ticketpulse-notifications:3108
      SEARCH_SERVICE_URL: http://ticketpulse-search:3109
      ADMIN_SERVICE_URL: http://ticketpulse-admin:3110
      REPORTING_SERVICE_URL: http://ticketpulse-reporting:3111
      STORAGE_SERVICE_URL: http://ticketpulse-storage:3112
    depends_on:
      - ticketpulse-auth
      - ticketpulse-user
      - ticketpulse-events
      - ticketpulse-venues
      - ticketpulse-inventory
      - ticketpulse-bookings
      - ticketpulse-payments
      - ticketpulse-notifications
      - ticketpulse-search
      - ticketpulse-admin
      - ticketpulse-reporting
      - ticketpulse-storage
    command: npm run dev -- -H 0.0.0.0 -p 3000

